# Staging Node.js runtime
NODE_ENV=production

# Staging port
PORT=4000

# Public base path
APP_BASE_PATH=/serverXR

# Keep staging data separate from production
DATA_ROOT=/home/your-user/serverXR-staging/data
SHARED_ROOT=/home/your-user/shared

# Auth off on staging — open access for testing
REQUIRE_AUTH=false
API_TOKEN=change-me

# Allow your staging frontend origin
CORS_ORIGINS=https://staging.your-domain

# Upload size cap in MB
MAX_UPLOAD_MB=100
