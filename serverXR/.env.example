# Server listening port
PORT=4000

# Base path when running behind a reverse proxy (leave blank for root)
APP_BASE_PATH=/serverXR

# Where scene + asset data is stored (relative to serverXR/)
DATA_ROOT=./data
# Optional: override nested directories
# SPACES_DIR=./data/spaces
# UPLOADS_DIR=./data/uploads
# DB_PATH=./data/di.db

# Temporary spaces cleanup (default 30 days, in ms)
SPACE_TTL_MS=2592000000

# Security (recommended in production)
# Legacy admin token. Backward-compatible and still accepted for automation.
API_TOKEN=change-me
# Optional role-specific tokens. Editors can modify project/scene content but cannot manage spaces.
# EDITOR_API_TOKEN=change-editor-token
# EDITOR_ALLOWED_SPACES=main,client-a
# VIEWER_API_TOKEN=change-viewer-token
# Optional stronger separation when API_TOKEN should not be the browser-login secret.
# AUTH_SESSION_SECRET=change-session-secret
REQUIRE_AUTH=true

# CORS allowed origins (comma-separated). Use * only for local development.
# Example: https://your-domain.com,https://www.your-domain.com
# Local dev example: http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=https://your-domain.com

# Max upload size in MB for assets (default 100)
MAX_UPLOAD_MB=100

# OAuth — GitHub (create app at https://github.com/settings/developers)
# Callback URL: https://di-studio.xyz/serverXR/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# OAuth — Google (create app at https://console.cloud.google.com/apis/credentials)
# Callback URL: https://di-studio.xyz/serverXR/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Base URL used to build OAuth callback URLs (no trailing slash)
# OAUTH_CALLBACK_BASE_URL=https://di-studio.xyz/serverXR
