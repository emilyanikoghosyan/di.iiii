# ── Docker / Node setup ────────────────────────────────────────────────────────
# Copy this file to .env and fill in values before running:
#   cp .env.example .env && docker compose up -d

# Port the app is accessible on the host.
# Use 80 on a root server or Docker Desktop. Use 8080+ on rootless Linux (Podman).
PORT=8080

# ── Auth ───────────────────────────────────────────────────────────────────────
# Set REQUIRE_AUTH=true to lock the instance behind token auth.
# Generate strong random strings: openssl rand -hex 32
REQUIRE_AUTH=false
ADMIN_API_TOKEN=
AUTH_SESSION_SECRET=

# Set to true when serving over HTTPS (recommended in production)
AUTH_SESSION_COOKIE_SECURE=false

# ── Uploads ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=100

# ── CORS ───────────────────────────────────────────────────────────────────────
# Leave empty when client and server share the same nginx origin (default Docker setup).
# Set to a comma-separated list of allowed origins if using a separate API host.
CORS_ORIGINS=

# ── Frontend API base URL ──────────────────────────────────────────────────────
# Leave empty in the default Docker setup — nginx proxies /serverXR/* automatically.
# Set to an absolute URL only if client and server are on different origins.
VITE_API_BASE_URL=

# ── Cloudflare Tunnel (optional) ───────────────────────────────────────────────
# Leave empty to use a free random *.trycloudflare.com URL (no account needed).
# Set to your named tunnel token for a fixed domain (from Cloudflare dashboard).
CLOUDFLARE_TUNNEL_TOKEN=

# ── Production image registry ──────────────────────────────────────────────────
# Used by docker-compose.prod.yml — set to your GitHub username or org.
REGISTRY_USER=youruser
IMAGE_TAG=latest

# ── Local dev only ─────────────────────────────────────────────────────────────
# Uncomment for local non-Docker dev where serverXR runs on a separate port:
# VITE_API_BASE_URL=http://localhost:4000

# ── Space sync (space:pull / space:push scripts) ───────────────────────────────
# Copy to .env.local and fill in — never commit .env.local
# Live server base URL (with serverXR path prefix):
LIVE_API_URL=https://di-studio.xyz/serverXR
# Local server base URL:
LOCAL_API_URL=http://localhost:4000/serverXR
# Auth token for writing to the live server (editor or admin role):
# Generate with: openssl rand -hex 32 — must match EDITOR_API_TOKEN or ADMIN_API_TOKEN on the live server
LIVE_API_TOKEN=
